{
  "name": "binance-local-watcher-electron-local-engine",
  "version": "0.4.0",
  "description": "Binance Local Watcher Electron UI with a local Node calculation engine. No real orders.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "smoke": "node scripts/smoke_local_engine.js",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.kabu-cutter.binance-local-watcher",
    "productName": "Binance Local Watcher",
    "asar": true,
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "local_engine.js",
      "local_engine_calculations.js",
      "API_CONTRACT.json",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1"
  }
}
