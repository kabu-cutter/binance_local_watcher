# Binance Local Watcher local environment sample
#
# Copy this file to .env when you need local credentials.
# Never commit .env. Keep Binance keys read-only where possible.

# Optional: signed read-only Binance APIs, such as account/commission checks.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Optional: override local project directory for generated data.
BLW_PROJECT_DIR=

# Optional: local Ollama endpoint.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
